{
  "name": "tape",
  "version": "0.1.0",
  "description": "Team meeting capture, transcription, review, and follow-up workspace.",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glazec/tape.git"
  },
  "scripts": {
    "dev": "next dev",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "build": "next build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "build:image-worker": "esbuild services/image-worker/server.ts --bundle --platform=node --target=node24 --format=esm --packages=external --outfile=dist/image-worker/server.mjs",
    "start": "next start",
    "start:image-worker": "node dist/image-worker/server.mjs",
    "inngest:sync": "node scripts/sync-inngest.mjs",
    "inngest:sync:image-worker": "node scripts/sync-image-worker-inngest.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:deployment-schema": "vitest run tests/migrations.test.ts",
    "test:calendar-live": "node --env-file-if-exists=.env.local --import=tsx scripts/verify-calendar-connection.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:mcp": "cd mcp/meeting-note && DISABLE_AUTH=true MCP_ALLOW_DEV_AUTH=true MCP_HOST=127.0.0.1 MCP_DEV_USER_EMAIL=tester@example.com uv run python -m unittest",
    "test:sidecar": "npm --prefix mac/LocalRecorder/Sidecar test",
    "test:swift": "swift test --package-path mac/LocalRecorder",
    "verify": "npm run lint && npm run test:coverage && npm run build && npm run test:sidecar && npm run test:mcp",
    "verify:all": "npm run verify && npm run test:swift && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@base-ui/react": "^1.6.0",
    "@elevenlabs/elevenlabs-js": "^2.53.1",
    "@neondatabase/auth": "^0.4.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "ffmpeg-static": "^5.3.0",
    "inngest": "^4.8.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "better-auth": "1.6.20",
    "@better-auth/passkey": "1.6.20",
    "postcss": "8.5.15",
    "esbuild": "0.28.1"
  }
}
